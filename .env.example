APP_NAME=OpenTeacher
APP_ENV=development
DATABASE_URL=postgresql+psycopg://openteacher:openteacher@postgres:5432/openteacher
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

POSTGRES_DB=openteacher
POSTGRES_USER=openteacher
POSTGRES_PASSWORD=openteacher
POSTGRES_HOST_PORT=127.0.0.1:5432
BACKEND_HOST_PORT=127.0.0.1:8000
FRONTEND_HOST_PORT=127.0.0.1:5173
ADMINER_HOST_PORT=127.0.0.1:8080
REDIS_HOST_PORT=127.0.0.1:6379
QDRANT_HTTP_HOST_PORT=127.0.0.1:6333
QDRANT_GRPC_HOST_PORT=127.0.0.1:6334

MEMORY_BACKEND=mock
RAG_BACKEND=mock

# Keep mock by default. To use Doubao, set LLM_PROVIDER=doubao and fill the token/model below.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_MAX_OUTPUT_TOKENS=700
OPENAI_TIMEOUT_SECONDS=30
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=
DOUBAO_MAX_TOKENS=700
DOUBAO_TIMEOUT_SECONDS=30

VITE_BACKEND_ORIGIN=http://backend:8000
VITE_API_BASE_URL=
